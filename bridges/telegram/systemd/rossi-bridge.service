[Unit]
Description=Rossi Telegram Chat Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mical
Group=mical
WorkingDirectory=/home/mical/fde/palette/bridges/telegram
EnvironmentFile=/home/mical/fde/palette/bridges/telegram/systemd/rossi-bridge.env
ExecStart=/usr/bin/python3 /home/mical/fde/palette/bridges/telegram/rossi_bridge.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ReadWritePaths=/home/mical/fde/implementations/retail/retail-rossi-store /home/mical/fde/implementations/retail/retail-rossi-store/telegram
ReadOnlyPaths=/home/mical/fde/palette/bridges/telegram
UMask=0077

[Install]
WantedBy=multi-user.target
