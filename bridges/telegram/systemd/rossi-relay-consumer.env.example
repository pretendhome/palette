# Copy to:
#   /home/mical/fde/palette/bridges/telegram/systemd/rossi-relay-consumer.env

# Enable live Orch handoff for `orch_summary_request` intents (optional; default off)
PALETTE_RELAY_ORCH_ENABLED=0

# Safe modes only: route | plan
PALETTE_RELAY_ORCH_MODE=plan

# Optional overrides
# PALETTE_RELAY_ORCH_BIN=/home/mical/fde/palette/agents/orchestrator/orch
# PALETTE_RELAY_ORCH_TIMEOUT_SEC=25
# PALETTE_IMPLEMENTATIONS_ROOT=/home/mical/fde/implementations

