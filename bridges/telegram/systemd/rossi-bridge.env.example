# Copy to:
#   /home/mical/fde/palette/bridges/telegram/systemd/rossi-bridge.env
# and set real values before enabling the service.

# Telegram bot token for @rossi_mission_bot (rotate if exposed)
ROSSI_BOT_TOKEN=REPLACE_ME

# Inference key for direct Anthropic path used by rossi_bridge.py
ANTHROPIC_API_KEY=REPLACE_ME

# Optional overrides
# PALETTE_IMPLEMENTATIONS_ROOT=/home/mical/fde/implementations
# ROSSI_RELAY_ENABLED=1
