{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandoffPacket",
  "description": "Canonical wire contract: structured input to any Palette agent. 7 fields.",
  "type": "object",
  "required": ["id", "from", "to", "task"],
  "properties": {
    "id":       { "type": "string", "description": "Unique packet identifier (UUID)" },
    "from":     { "type": "string", "description": "Sending agent" },
    "to":       { "type": "string", "description": "Receiving agent" },
    "task":     { "type": "string", "description": "Single bounded objective" },
    "riu_ids":  { "type": "array", "items": { "type": "string" }, "description": "Relevant RIU identifiers" },
    "payload":  { "type": "object", "description": "Agent-specific structured data (extension point)" },
    "trace_id": { "type": "string", "description": "Groups packets in one session/task chain" }
  },
  "additionalProperties": false
}
