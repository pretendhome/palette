{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandoffResult",
  "description": "Canonical wire contract: structured output from any Palette agent. 7 fields.",
  "type": "object",
  "required": ["packet_id", "from", "status"],
  "properties": {
    "packet_id":  { "type": "string", "description": "ID of the packet this answers (invariant: result.packet_id == packet.id)" },
    "from":       { "type": "string", "description": "Agent that produced this result" },
    "status":     { "type": "string", "enum": ["success", "failure", "blocked"], "description": "Closed enum: success | failure | blocked" },
    "output":     { "type": "object", "description": "Structured agent output (extension point)" },
    "blockers":   { "type": "array", "items": { "type": "string" }, "description": "What prevented completion (required if status != success)" },
    "artifacts":  { "type": "array", "items": { "type": "string" }, "description": "Files or resources produced" },
    "next_agent": { "type": "string", "description": "Suggested next routing target" }
  },
  "additionalProperties": false
}
