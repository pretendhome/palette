#!/usr/bin/env python3
"""palette — CLI entry point.

Usage:
  palette query "how do governance tiers work?"
  palette query --learn "what is taxonomy routing?"
  palette query --json --trace "convergence protocol"
  palette health
"""
import sys
from pathlib import Path

COMMANDS = {
    "query": "palette_query",
    "health": None,  # future
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("palette — Governed runtime CLI\n")
        print("Commands:")
        print("  query   Run the 5-step query pipeline (resolve → retrieve → route → respond → extract)")
        print("  health  Run integrity checks (coming soon)")
        print("\nUsage: palette query \"your question here\" [--learn] [--json] [--trace]")
        sys.exit(0)

    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        print(f"Unknown command: {cmd}. Available: {', '.join(COMMANDS.keys())}")
        sys.exit(1)

    if cmd == "query":
        import subprocess
        script = Path(__file__).parent / "palette_query.py"
        result = subprocess.run(
            [sys.executable, str(script)] + sys.argv[2:],
            cwd=str(Path(__file__).parent.parent),
        )
        sys.exit(result.returncode)
    elif cmd == "health":
        print("palette health — coming soon. Use: uv run python scripts/palette_intelligence_system/integrity.py")
        sys.exit(0)


if __name__ == "__main__":
    main()
